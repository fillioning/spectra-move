{
    "id": "spectra",
    "name": "Spectra",
    "abbrev": "SPCTRA",
    "version": "0.1.1",
    "description": "Multiband spectral resonator with pitch tracking and scale quantization",
    "author": "fillioning",
    "dsp": "spectra.so",
    "api_version": 2,
    "component_type": "audio_fx",
    "capabilities": {
        "chainable": true,
        "component_type": "audio_fx",
        "ui_hierarchy": {
            "modes": null,
            "levels": {
                "root": {
                    "name": "Spectra",
                    "knobs": ["onset", "frequency", "brightness", "timbre", "decay", "root_note", "scale", "mix"],
                    "params": [
                        { "level": "Main", "label": "Spectra" },
                        { "level": "Control", "label": "Control" }
                    ]
                },
                "Main": {
                    "label": "Spectra",
                    "knobs": ["onset", "frequency", "brightness", "timbre", "decay", "root_note", "scale", "mix"],
                    "params": [
                        { "key": "onset",      "label": "Onset",      "type": "float", "min": 0, "max": 1, "default": 0.7, "step": 0.01 },
                        { "key": "frequency",  "label": "Frequency",  "type": "float", "min": 0, "max": 1, "default": 0.3, "step": 0.01 },
                        { "key": "brightness", "label": "Brightness", "type": "float", "min": 0, "max": 1, "default": 0.3, "step": 0.01 },
                        { "key": "timbre",     "label": "Timbre",     "type": "float", "min": 0, "max": 1, "default": 0.0, "step": 0.01 },
                        { "key": "decay",      "label": "Decay",      "type": "float", "min": 0, "max": 1, "default": 0.5, "step": 0.01 },
                        { "key": "root_note",  "label": "Root",       "type": "enum",  "options": ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"], "default": 0 },
                        { "key": "scale",      "label": "Scale",      "type": "enum",  "options": ["Major","Nat Minor","Harm Minor","Mel Minor","Dorian","Phrygian","Lydian","Mixolydian","Penta Maj","Penta Min","Blues","Chromatic"], "default": 0 },
                        { "key": "mix",        "label": "Mix",        "type": "float", "min": 0, "max": 1, "default": 1.0, "step": 0.01 }
                    ]
                },
                "Control": {
                    "label": "Control",
                    "knobs": ["chord_drift", "resonators", "octave_range", "compress", "pre_gain", "post_gain", "hpf", "lpf"],
                    "params": [
                        { "key": "chord_drift",  "label": "Chord Drift", "type": "float", "min": 0, "max": 1, "default": 0.0, "step": 0.01 },
                        { "key": "resonators",   "label": "Resonators",  "type": "enum",  "options": ["5","7","12"], "default": 2 },
                        { "key": "octave_range", "label": "Oct Range",   "type": "enum",  "options": ["1","2","3","4"], "default": 1 },
                        { "key": "compress",     "label": "Compress",    "type": "float", "min": 0, "max": 1, "default": 0.2, "step": 0.01 },
                        { "key": "pre_gain",     "label": "Pre Gain",    "type": "float", "min": -12, "max": 12, "default": 0.0, "step": 0.5 },
                        { "key": "post_gain",    "label": "Post Gain",   "type": "float", "min": -12, "max": 12, "default": 0.0, "step": 0.5 },
                        { "key": "hpf",          "label": "HPF",         "type": "int", "min": 20, "max": 2000, "default": 20, "step": 1 },
                        { "key": "lpf",          "label": "LPF",         "type": "int", "min": 500, "max": 20000, "default": 20000, "step": 1 },
                        { "key": "limiter",      "label": "Limiter",     "type": "enum",  "options": ["Off","On"], "default": 1 },
                        { "key": "polyphony",    "label": "Polyphony",   "type": "enum",  "options": ["1","2","4"], "default": 2 }
                    ]
                }
            }
        },
        "chain_params": [
            {"key": "onset",        "name": "Onset",       "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "frequency",    "name": "Frequency",   "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "brightness",   "name": "Brightness",  "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "timbre",       "name": "Timbre",      "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "decay",        "name": "Decay",       "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "root_note",    "name": "Root",        "type": "enum",  "options": ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"]},
            {"key": "scale",        "name": "Scale",       "type": "enum",  "options": ["Major","Nat Minor","Harm Minor","Mel Minor","Dorian","Phrygian","Lydian","Mixolydian","Penta Maj","Penta Min","Blues","Chromatic"]},
            {"key": "mix",          "name": "Mix",         "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "chord_drift",  "name": "Chord Drift", "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "resonators",   "name": "Resonators",  "type": "enum",  "options": ["5","7","12"]},
            {"key": "octave_range", "name": "Oct Range",   "type": "enum",  "options": ["1","2","3","4"]},
            {"key": "compress",     "name": "Compress",    "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "pre_gain",     "name": "Pre Gain",    "type": "float", "min": -12,  "max": 12,    "step": 0.5},
            {"key": "post_gain",    "name": "Post Gain",   "type": "float", "min": -12,  "max": 12,    "step": 0.5},
            {"key": "hpf",          "name": "HPF",         "type": "int",   "min": 20,   "max": 2000,  "step": 1},
            {"key": "lpf",          "name": "LPF",         "type": "int",   "min": 500,  "max": 20000, "step": 1},
            {"key": "limiter",      "name": "Limiter",     "type": "enum",  "options": ["Off","On"]},
            {"key": "polyphony",    "name": "Polyphony",   "type": "enum",  "options": ["1","2","4"]}
        ]
    }
}
