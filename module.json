{
    "id": "spectra",
    "name": "Spectra",
    "abbrev": "SPCTRA",
    "version": "0.2.0",
    "description": "Multiband spectral resonator with pitch tracking and scale quantization",
    "author": "fillioning",
    "dsp": "spectra.so",
    "api_version": 2,
    "component_type": "audio_fx",
    "capabilities": {
        "chainable": true,
        "component_type": "audio_fx",
        "ui_hierarchy": {
            "modes": null,
            "levels": {
                "root": {
                    "name": "Spectra",
                    "knobs": ["onset", "frequency", "brightness", "timbre", "decay", "root_note", "scale", "mix"],
                    "params": [
                        { "level": "Main", "label": "Spectra" },
                        { "level": "Control", "label": "Control" },
                        { "level": "Motion", "label": "Motion" },
                        { "level": "Patch", "label": "Patch" }
                    ]
                },
                "Main": {
                    "label": "Spectra",
                    "knobs": ["onset", "frequency", "brightness", "timbre", "decay", "root_note", "scale", "mix"],
                    "params": [
                        { "key": "onset",      "label": "Onset",      "type": "float", "min": 0, "max": 1, "default": 0.7, "step": 0.01 },
                        { "key": "frequency",  "label": "Frequency",  "type": "float", "min": 0, "max": 1, "default": 0.3, "step": 0.01 },
                        { "key": "brightness", "label": "Brightness", "type": "float", "min": 0, "max": 1, "default": 0.3, "step": 0.01 },
                        { "key": "timbre",     "label": "Timbre",     "type": "float", "min": 0, "max": 1, "default": 0.0, "step": 0.01 },
                        { "key": "decay",      "label": "Decay",      "type": "float", "min": 0, "max": 1, "default": 0.5, "step": 0.01 },
                        { "key": "root_note",  "label": "Root",       "type": "enum",  "options": ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"], "default": 0 },
                        { "key": "scale",      "label": "Scale",      "type": "enum",  "options": ["Major","Nat Minor","Harm Minor","Mel Minor","Dorian","Phrygian","Lydian","Mixolydian","Penta Maj","Penta Min","Blues","Chromatic"], "default": 0 },
                        { "key": "mix",        "label": "Mix",        "type": "float", "min": 0, "max": 1, "default": 1.0, "step": 0.01 }
                    ]
                },
                "Control": {
                    "label": "Control",
                    "knobs": ["chord_drift", "resonators", "octave_range", "compress", "pre_gain", "post_gain", "hpf", "lpf"],
                    "params": [
                        { "key": "chord_drift",  "label": "Chord Drift", "type": "float", "min": 0, "max": 1, "default": 0.0, "step": 0.01 },
                        { "key": "resonators",   "label": "Resonators",  "type": "enum",  "options": ["5","7","12"], "default": 2 },
                        { "key": "octave_range", "label": "Oct Range",   "type": "enum",  "options": ["1","2","3","4"], "default": 1 },
                        { "key": "compress",     "label": "Compress",    "type": "float", "min": 0, "max": 1, "default": 0.2, "step": 0.01 },
                        { "key": "pre_gain",     "label": "Pre Gain",    "type": "float", "min": -12, "max": 12, "default": 0.0, "step": 0.5 },
                        { "key": "post_gain",    "label": "Post Gain",   "type": "float", "min": -12, "max": 12, "default": 0.0, "step": 0.5 },
                        { "key": "hpf",          "label": "HPF",         "type": "int", "min": 20, "max": 2000, "default": 20, "step": 1 },
                        { "key": "lpf",          "label": "LPF",         "type": "int", "min": 500, "max": 20000, "default": 20000, "step": 1 },
                        { "key": "limiter",      "label": "Limiter",     "type": "enum",  "options": ["Off","On"], "default": 1 },
                        { "key": "polyphony",    "label": "Polyphony",   "type": "enum",  "options": ["1","2","4"], "default": 2 }
                    ]
                },
                "Motion": {
                    "label": "Motion",
                    "knobs": ["arp_rate", "arp_pattern", "arp_sync", "drift", "motion_rate", "motion_depth", "motion_shape", "scoop"],
                    "params": [
                        { "key": "arp_rate",      "label": "Arp Rate",    "type": "float", "min": 0, "max": 1, "default": 0.5, "step": 0.01 },
                        { "key": "arp_pattern",   "label": "Arp Ptrn",    "type": "enum",  "options": ["Off", "Up", "Down", "Random", "Chord"], "default": 0 },
                        { "key": "arp_sync",      "label": "Arp Sync",    "type": "enum",  "options": ["Free", "Sync"], "default": 0 },
                        { "key": "drift",         "label": "Drift",       "type": "float", "min": 0, "max": 1, "default": 0.0, "step": 0.01 },
                        { "key": "motion_rate",   "label": "Mot Rate",    "type": "float", "min": 0, "max": 1, "default": 0.3, "step": 0.01 },
                        { "key": "motion_depth",  "label": "Mot Depth",   "type": "float", "min": 0, "max": 1, "default": 0.0, "step": 0.01 },
                        { "key": "motion_shape",  "label": "Mot Shape",   "type": "enum",  "options": ["Sine", "Triangle", "Square", "S&H"], "default": 0 },
                        { "key": "scoop",         "label": "Scoop",       "type": "float", "min": 0, "max": 1, "default": 0.0, "step": 0.01 }
                    ]
                },
                "Patch": {
                    "label": "Patch",
                    "knobs": ["preset", "rnd_preset", "rnd_spectra", "rnd_motion", "rnd_pan", "stereo_width"],
                    "params": [
                        { "key": "preset",       "label": "Preset",       "type": "enum", "options": ["Bell", "Pad", "Arp Up", "Arp Rnd", "Drifter", "Shimmer", "Drone Bass", "Tremolo", "Bells", "Scooped", "Evolving", "Stutter", "Resonant", "Wavy", "Pulsing", "Minimal", "Lush", "Crisp", "Glitch", "Warm", "Bright", "Deep", "Airy", "Metallic", "Modulating", "Sparse", "Liquid", "Rhythmic", "Spacious", "Chaos"], "default": 0 },
                        { "key": "rnd_preset",   "label": "Rnd Preset",   "type": "int", "min": 0, "max": 1, "default": 0, "step": 1 },
                        { "key": "rnd_spectra",  "label": "Rnd Spectra",  "type": "int", "min": 0, "max": 1, "default": 0, "step": 1 },
                        { "key": "rnd_motion",   "label": "Rnd Motion",   "type": "int", "min": 0, "max": 1, "default": 0, "step": 1 },
                        { "key": "rnd_pan",      "label": "Rnd Pan",      "type": "int", "min": 0, "max": 1, "default": 0, "step": 1 },
                        { "key": "stereo_width", "label": "Stereo Width", "type": "float", "min": 0, "max": 1, "default": 1.0, "step": 0.01 }
                    ]
                }
            }
        },
        "chain_params": [
            {"key": "onset",        "name": "Onset",       "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "frequency",    "name": "Frequency",   "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "brightness",   "name": "Brightness",  "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "timbre",       "name": "Timbre",      "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "decay",        "name": "Decay",       "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "root_note",    "name": "Root",        "type": "enum",  "options": ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"]},
            {"key": "scale",        "name": "Scale",       "type": "enum",  "options": ["Major","Nat Minor","Harm Minor","Mel Minor","Dorian","Phrygian","Lydian","Mixolydian","Penta Maj","Penta Min","Blues","Chromatic"]},
            {"key": "mix",          "name": "Mix",         "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "chord_drift",  "name": "Chord Drift", "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "resonators",   "name": "Resonators",  "type": "enum",  "options": ["5","7","12"]},
            {"key": "octave_range", "name": "Oct Range",   "type": "enum",  "options": ["1","2","3","4"]},
            {"key": "compress",     "name": "Compress",    "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "pre_gain",     "name": "Pre Gain",    "type": "float", "min": -12,  "max": 12,    "step": 0.5},
            {"key": "post_gain",    "name": "Post Gain",   "type": "float", "min": -12,  "max": 12,    "step": 0.5},
            {"key": "hpf",          "name": "HPF",         "type": "int",   "min": 20,   "max": 2000,  "step": 1},
            {"key": "lpf",          "name": "LPF",         "type": "int",   "min": 500,  "max": 20000, "step": 1},
            {"key": "limiter",      "name": "Limiter",     "type": "enum",  "options": ["Off","On"]},
            {"key": "polyphony",    "name": "Polyphony",   "type": "enum",  "options": ["1","2","4"]},
            {"key": "arp_rate",     "name": "Arp Rate",    "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "arp_pattern",  "name": "Arp Ptrn",    "type": "enum",  "options": ["Off","Up","Down","Random","Chord"]},
            {"key": "arp_sync",     "name": "Arp Sync",    "type": "enum",  "options": ["Free","Sync"]},
            {"key": "drift",        "name": "Drift",       "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "motion_rate",  "name": "Mot Rate",    "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "motion_depth", "name": "Mot Depth",   "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "motion_shape", "name": "Mot Shape",   "type": "enum",  "options": ["Sine","Triangle","Square","S&H"]},
            {"key": "scoop",        "name": "Scoop",       "type": "float", "min": 0,    "max": 1,     "step": 0.01},
            {"key": "preset",       "name": "Preset",      "type": "enum",  "options": ["Bell","Pad","Arp Up","Arp Rnd","Drifter","Shimmer","Drone Bass","Tremolo","Bells","Scooped","Evolving","Stutter","Resonant","Wavy","Pulsing","Minimal","Lush","Crisp","Glitch","Warm","Bright","Deep","Airy","Metallic","Modulating","Sparse","Liquid","Rhythmic","Spacious","Chaos"]},
            {"key": "rnd_preset",   "name": "Rnd Preset",  "type": "int", "min": 0, "max": 1, "step": 1},
            {"key": "rnd_spectra",  "name": "Rnd Spectra", "type": "int", "min": 0, "max": 1, "step": 1},
            {"key": "rnd_motion",   "name": "Rnd Motion",  "type": "int", "min": 0, "max": 1, "step": 1},
            {"key": "rnd_pan",      "name": "Rnd Pan",     "type": "int", "min": 0, "max": 1, "step": 1},
            {"key": "stereo_width", "name": "Stereo Width","type": "float", "min": 0,    "max": 1,     "step": 0.01}
        ]
    }
}
